# LeetFut environment configuration
# Copy to .env.local and fill in.

# Base URL of an alfa-leetcode-api instance (https://github.com/alfaarghya/alfa-leetcode-api).
# Recommended: self-host it (the public demo cold-starts and is rate-limited):
#   docker run -p 3000:3000 alfaarghya/alfa-leetcode-api:2.0.4
# When UNSET, the app runs in demo mode and only serves the built-in sample cards.
LEETCODE_API_BASE=http://localhost:3000

# Optional. Redis connection string for the read-through card cache.
# When unset, every scout is fetched + scored live (no caching).
# REDIS_URL=redis://localhost:6379

# Optional. Umami Cloud analytics (https://cloud.umami.is) — visitors + region
# breakdown on the Umami dashboard. When unset, no tracking script is injected.
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id

# Optional. Public origin used for share links, OG images, sitemap and JSON-LD.
# Defaults to https://leetfut.com when unset.

